{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowJs": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
